    </servlet>
    <servlet-mapping>
        <servlet-name>ViewGraniteStockServlet</servlet-name>
        <url-pattern>/viewGraniteStock</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteGraniteStockServlet</servlet-name>
