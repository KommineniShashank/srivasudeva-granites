    </servlet>
    <servlet-mapping>
        <servlet-name>AddGraniteServlet</servlet-name>
        <url-pattern>/addGranite</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>AddExpenseServlet</servlet-name>
        <servlet-class>com.granite.servlet.AddExpenseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AddExpenseServlet</servlet-name>
        <url-pattern>/addExpense</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>SaveBillServlet</servlet-name>
        <servlet-class>com.granite.servlet.SaveBillServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SaveBillServlet</servlet-name>
        <url-pattern>/saveBill</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateBillServlet</servlet-name>
        <servlet-class>com.granite.servlet.UpdateBillServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateBillServlet</servlet-name>
        <url-pattern>/updateBill</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewBillsServlet</servlet-name>
        <servlet-class>com.granite.servlet.ViewBillsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewBillsServlet</servlet-name>
        <url-pattern>/viewBills</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ViewBillDetailsServlet</servlet-name>
        <servlet-class>com.granite.servlet.ViewBillDetailsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ViewBillDetailsServlet</servlet-name>
        <url-pattern>/viewBillDetails</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteBillServlet</servlet-name>
        <servlet-class>com.granite.servlet.DeleteBillServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteBillServlet</servlet-name>
        <url-pattern>/deleteBill</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>InvoiceServlet</servlet-name>
