    </servlet-mapping>

    <servlet>
        <servlet-name>UpdateExpenseServlet</servlet-name>
        <servlet-class>com.granite.servlet.UpdateExpenseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>UpdateExpenseServlet</servlet-name>
        <url-pattern>/updateExpense</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>DeleteExpenseServlet</servlet-name>
        <servlet-class>com.granite.servlet.DeleteExpenseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>DeleteExpenseServlet</servlet-name>
        <url-pattern>/deleteExpense</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ExportExpensesExcelServlet</servlet-name>
        <servlet-class>com.granite.servlet.ExportExpensesExcelServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ExportExpensesExcelServlet</servlet-name>
        <url-pattern>/exportExpensesExcel</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>ProfitReportServlet</servlet-name>
        <servlet-class>com.granite.servlet.ProfitReportServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>ProfitReportServlet</servlet-name>
        <url-pattern>/profitReport</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>MeasurementPdfServlet</servlet-name>
        <servlet-class>com.granite.servlet.MeasurementPdfServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>MeasurementPdfServlet</servlet-name>
        <url-pattern>/measurementPdf</url-pattern>
    </servlet-mapping>

</web-app>
